
# Entorno
NODE_ENV=development
APP_ENV=development
APP_PORT=3000

# Base de datos PostgreSQL
# Opción 1: Usando variables individuales (local)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=pufa_db

# Opción 2: Usando DATABASE_URL (comentar opción 1 si usas esta)
# DATABASE_URL=postgresql://usuario:contraseña@host:puerto/base_datos

# JWT
JWT_SECRET=tu_secreto_super_seguro_con_32_caracteres_minimo_en_produccion
