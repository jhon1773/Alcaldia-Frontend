# Base de datos PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=password
DB_DATABASE=pufa_db

# JWT
JWT_SECRET=tu_secreto_jwt_muy_seguro_aqui
JWT_EXPIRATION=1d

# Aplicación
APP_PORT=3000
APP_ENV=development
API_PREFIX=api/v1

# Archivos
MAX_FILE_SIZE_MB=10
UPLOAD_DEST=./uploads

# Abono
PORCENTAJE_ABONO_DEFAULT=30

# Tiempo de aprobación (días hábiles)
DIAS_HABILES_MIN=5
DIAS_HABILES_MAX=15
